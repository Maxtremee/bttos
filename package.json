{
  "name": "bttos",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "preview": "vite preview",
    "test": "vitest run --reporter=verbose --passWithNoTests",
    "package": "vite build && cp appinfo.json icon.png largeIcon.png dist/ && cp -r webOSTVjs-1.2.13 dist/ && ares-package --no-minify dist/ -o .",
    "deploy": "npm run package && source ~/.nvm/nvm.sh && nvm use 18 && node /Users/maksymilianzadka/.nvm/versions/node/v24.14.1/lib/node_modules/@webos-tools/cli/bin/ares-install.js com.dev.bttos_0.1.0_all.ipk",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@lampa-dev/solidjs-spatial-navigation": "^1.0.0",
    "@solidjs/router": "^0.16.1",
    "hls.js": "^1.6.16",
    "solid-js": "^1.9.12",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitejs/plugin-legacy": "^6.1.1",
    "@webos-tools/cli": "^3.2.3",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "terser": "^5.46.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^3.1.2"
  }
}
